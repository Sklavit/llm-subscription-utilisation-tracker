<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sklavit.claude-usage.account</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>$HOME/.claude-usage-archive/usage.py</string>
        <string>--record-limits</string>
    </array>
    <key>StartInterval</key><integer>1800</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key><string>$HOME/.claude-usage-archive/account.log</string>
    <key>StandardErrorPath</key><string>$HOME/.claude-usage-archive/account.log</string>
</dict>
</plist>
